msgstr ""
":ref:`התקן <general/install>` את המודולים הבאים כדי לקבל את כל התכונות של "
"לוקליזציית השכר של ערב הסעודית:"

#: ../../content/applications/hr/payroll/payroll_localizations/saudi_arabia.rst:32
msgid ":guilabel:`Saudi Arabia - Payroll`"
msgstr ":guilabel:`ערב הסעודית - שכר`"

#: ../../content/applications/hr/payroll/payroll_localizations/saudi_arabia.rst:33
