msgid ":doc:`Log expenses <log_expenses>`"
msgstr ":doc:`Registrar despesas <log_expenses>`"

#: ../../content/applications/finance/expenses/reinvoice_expenses.rst:29
msgid ":doc:`Expense reports <expense_reports>`"
msgstr ":doc:`Relatórios de despesas <expense_reports>`"

