msgstr ""
"אם בדיקת Turnstile נכשלת, מבקרים לא יכולים לשלוח את הטופס, והודעת השגיאה "
"הבאה מוצגת:"

#: ../../content/applications/websites/website/configuration/spam_protection.rst:0
msgid "Cloudflare Turnstile verification error message"
msgstr "הודעת שגיאת אימות Cloudflare Turnstile"

