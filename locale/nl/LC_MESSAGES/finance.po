msgstr "Handmatig uploaden"

#: ../../content/applications/finance/accounting/vendor_bills/invoice_digitization.rst:51
msgid ""
"From the :guilabel:`Accounting Dashboard`, click :guilabel:`Upload` on "
"the :guilabel:`Vendor Bills` journal."
msgstr ""

#: ../../content/applications/finance/accounting/vendor_bills/invoice_digitization.rst:57
