msgid ""
":guilabel:`Registration Number`: 9 digits code received from the NSSO (ONSS "
"- RSZ)"
msgstr ":guilabel:`登録番号`: NSSO(ONSS - RSZ)から受け取った9桁のコード"

#: ../../content/applications/hr/payroll/payroll_localizations/belgium.rst:850
