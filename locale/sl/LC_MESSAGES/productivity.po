#: ../../content/applications/productivity/phone/axivox/call_queues.rst:73
msgid ":guilabel:`Name`: name of the queue."
msgstr ":guilabel:`Name`: ime vrste."

#: ../../content/applications/productivity/phone/axivox/call_queues.rst:74
msgid ""
":guilabel:`Extension`: number of the extension to be dialed to reach the "
