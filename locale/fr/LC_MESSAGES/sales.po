#: ../../content/applications/sales/sales/sales_quotations/pdf_quote_builder/dynamic_text.rst:197
msgid ":guilabel:`client_order_ref`: Customer Reference"
msgstr ":guilabel:`client_order_ref` : Référence du client"

#: ../../content/applications/sales/sales/sales_quotations/pdf_quote_builder/dynamic_text.rst:200
msgid "For product PDF:"
msgstr "Pour le PDF produit :"

#: ../../content/applications/sales/sales/sales_quotations/pdf_quote_builder/dynamic_text.rst:202
msgid ":guilabel:`description`: Product Description"
msgstr ":guilabel:`description` : Description du produit"

#: ../../content/applications/sales/sales/sales_quotations/pdf_quote_builder/dynamic_text.rst:203
msgid ":guilabel:`quantity`: Quantity"
msgstr ":guilabel:`quantity` : Quantité"

#: ../../content/applications/sales/sales/sales_quotations/pdf_quote_builder/dynamic_text.rst:204
msgid ":guilabel:`uom`: Unit of Measure (UoM)"
msgstr ":guilabel:`uom` : Unité de mesure (UdM)"

#: ../../content/applications/sales/sales/sales_quotations/pdf_quote_builder/dynamic_text.rst:205
