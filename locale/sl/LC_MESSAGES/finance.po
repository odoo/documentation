msgstr "Nepoložena sredstva"

#: ../../content/applications/finance/accounting/get_started/cheat_sheet.rst:228
#: ../../content/applications/finance/accounting/get_started/cheat_sheet.rst:236
msgid "Check 0123"
msgstr "Ček 0123"

