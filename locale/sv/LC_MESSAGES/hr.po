msgid ":doc:`time_off/time_off_types`"
msgstr ":doc:`time_off/time_off_types`"

#: ../../content/applications/hr/time_off.rst:127
msgid ":doc:`time_off/public_holidays`"
msgstr ":doc:`time_off/public_holidays`"

#: ../../content/applications/hr/time_off.rst:128
msgid ":doc:`time_off/allocations`"
msgstr ":doc:`tid_off/tilldelningar`"

#: ../../content/applications/hr/time_off.rst:129
msgid ":doc:`time_off/accrual_plans`"
msgstr ":doc:`time_off/accrual_plans`"

#: ../../content/applications/hr/time_off.rst:130
msgid ":doc:`time_off/request_time_off`"
msgstr ":doc:`time_off/request_time_off`"

#: ../../content/applications/hr/time_off.rst:131
msgid ":doc:`time_off/my_time`"
msgstr ":doc:`time_off/my_time`"

#: ../../content/applications/hr/time_off.rst:132
msgid ":doc:`time_off/management`"
msgstr ":doc:`tid_off/management`"

#: ../../content/applications/hr/time_off.rst:133
