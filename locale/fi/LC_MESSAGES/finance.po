#: ../../content/applications/finance/fiscal_localizations/belgium.rst:165
msgid "Here is the list of Belgian-specific reports available:"
msgstr "Tässä on luettelo saatavilla olevista Belgia-kohtaisista raporteista:"

#: ../../content/applications/finance/fiscal_localizations/belgium.rst:167
msgid "Balance sheet;"
msgstr "Tase;"

#: ../../content/applications/finance/fiscal_localizations/belgium.rst:168
msgid "Profit & loss;"
msgstr "Tuloslaskelma;"

#: ../../content/applications/finance/fiscal_localizations/belgium.rst:169
msgid "Tax report;"
msgstr "Veroraportti;"

#: ../../content/applications/finance/fiscal_localizations/belgium.rst:170
