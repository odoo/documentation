msgstr "產假"

#: ../../content/applications/hr/payroll/payroll_localizations/egypt.rst:136
msgid "Hajj leave"
msgstr "朝聖假"

#: ../../content/applications/hr/payroll/payroll_localizations/egypt.rst:137
msgid "Death leave"
msgstr "喪假"

