#: ../../content/applications/marketing/marketing_automation/target_audience.rst:74
msgid ""
"With the above configuration, the campaign targets :guilabel:`157 record(s)`."
msgstr ""
"Dengan konfigurasi di atas, kampanye menargetkan :guilabel:`157 rekaman`."

