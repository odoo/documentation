msgstr ":guilabel:`NCRE-Credit Note`,"

#: ../../content/applications/finance/fiscal_localizations/guatemala.rst:24
msgid ":guilabel:`NDEB-Debit Note`,"
msgstr ":guilabel:`NDEB-Debit Note`,"

#: ../../content/applications/finance/fiscal_localizations/guatemala.rst:25
