msgstr "Odoo versiyasini ko'rsatadi, masalan \"Odoo Server 19.0\""

#: ../../content/developer/reference/cli.rst:56
msgid "You can enable auto-completion in your shell by running"
msgstr "Siz shellda avtomatik to'ldirishni quyidagilarni bajarish orqali yoqishingiz mumkin"

#: ../../content/developer/reference/cli.rst:66
msgid "`help` - Show available commands"
msgstr "`help` - Mavjud buyruqlarni ko'rsatish"

#: ../../content/developer/reference/cli.rst:70
msgid "This command shows all the available commands for Odoo."
msgstr "Bu buyruq Odoo uchun barcha mavjud buyruqlarni ko'rsatadi."

#: ../../content/developer/reference/cli.rst:72
