msgstr ":guilabel:`Тип идентификации`"

#: ../../content/applications/finance/fiscal_localizations/chile.rst:1103
msgid ":guilabel:`Tax Payer Type`"
msgstr ":guilabel:`Тип налогоплательщика`"

#: ../../content/applications/finance/fiscal_localizations/chile.rst:1104
