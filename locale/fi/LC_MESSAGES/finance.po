msgid ""
":doc:`Chart of accounts documentation <../accounting/get_started/"
"chart_of_accounts>`"
msgstr ""
":doc:`Tilikartan dokumentaatio <../accounting/get_started/chart_of_accounts>`"

#: ../../content/applications/finance/fiscal_localizations/austria.rst:125
msgid "Exporting the SAF-T report"
msgstr "SAF-T-raportin vieminen"

#: ../../content/applications/finance/fiscal_localizations/austria.rst:127
msgid ""
"To export the SAF-T report, go to :menuselection:`Accounting --> Reports --> "
"General Ledger`. Click the right side of the :guilabel:`PDF` button and "
"select :guilabel:`SAF-T`."
msgstr ""
"Vie SAF-T-raportti siirtymällä kohtaan :menuselection:`Kirjanpito --> "
"Raportit --> Pääkirja`. Napsauta :guilabel:`PDF`-painikkeen oikeaa puolta ja "
