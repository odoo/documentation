#: ../../content/applications/inventory_and_mrp/inventory/warehouses_storage/replenishment/lead_times.rst:68
msgid "Sales lead times"
msgstr "Plazos de entrega para ventas"

#: ../../content/applications/inventory_and_mrp/inventory/warehouses_storage/replenishment/lead_times.rst:70
msgid ""
"Customer lead times and sales security lead times can be configured to "
