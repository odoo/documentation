#: ../../content/applications/finance/accounting/customer_invoices/incoterms.rst:35
msgid "Define an Incoterm"
msgstr "Določite Incoterm"

#: ../../content/applications/finance/accounting/customer_invoices/incoterms.rst:37
msgid ""
"To define an Incoterm manually, create an invoice or bill, click "
"the :guilabel:`Other Info` tab, and select the :guilabel:`Incoterm`."
msgstr ""
"Za ročno določitev Incoterma ustvarite račun ali prejeti račun, kliknite "
