msgstr ""
":guilabel:`Имя пользователя`: введите имя пользователя для входа на сервер."

#: ../../content/applications/finance/fiscal_localizations/chile.rst:184
msgid ":guilabel:`Password`: enter the server login password."
msgstr ":guilabel:`Пароль`: введите пароль для входа на сервер."

