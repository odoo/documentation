msgid "Apply finish"
msgstr "फिनिश लगाएं"

#: ../../content/applications/inventory_and_mrp/manufacturing/advanced_configuration/work_order_dependencies.rst:134
msgid "Dry"
msgstr "सुखाएं"

#: ../../content/applications/inventory_and_mrp/manufacturing/advanced_configuration/work_order_dependencies.rst:136
