#: ../../content/applications/marketing/marketing_automation.rst:0
msgid ":icon:`fa-star` :guilabel:`Prioritize Hot leads`"
msgstr ":icon:`fa-star` :guilabel:`Ưu tiên Khách hàng tiềm năng Nóng`"

#: ../../content/applications/marketing/marketing_automation.rst:0
