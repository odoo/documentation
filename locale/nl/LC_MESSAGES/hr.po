msgstr "Actieve/Gearchiveerde Werknemers"

#: ../../content/applications/hr/attendances/attendance_logs.rst:93
msgid ""
"Switch between current staff and former employees when auditing historical "
"data."
msgstr ""
"Schakel tussen huidig personeel en voormalige werknemers bij het auditen van "
"historische gegevens."

#: ../../content/applications/hr/attendances/attendance_logs.rst:96
msgid "Insightful groupings"
msgstr "Inzichtelijke groeperingen"

#: ../../content/applications/hr/attendances/attendance_logs.rst:103
