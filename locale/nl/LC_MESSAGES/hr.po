"\\text{eindbedrag} = max(0, \\text{totaalbedrag} - \\text{dagelijkse "
"vermindering} \\times\n"
"\\text{ontbrekende dagen})"

#: ../../content/applications/hr/payroll/payroll_localizations/belgium.rst:2245
#, fuzzy
msgid "Final calculation"
