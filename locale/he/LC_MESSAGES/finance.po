#: ../../content/applications/finance/fiscal_localizations/spain.rst:None
msgid "Administrative center contact form for public entities."
msgstr "טופס איש קשר של מרכז מנהלי עבור ארגונים ציבוריים."

#: ../../content/applications/finance/fiscal_localizations/spain.rst:403
