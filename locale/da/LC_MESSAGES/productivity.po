msgstr ""
"reakce na existující komentářové vlákno v buňce, klikněte na příslušnou "
"buňku nebo na komentářové vlákno pro otevření vlákna."

#: ../../content/applications/productivity/spreadsheet/share_collaborate.rst:198
msgid "Type a comment in the text box."
msgstr "Skriv en kommentar i tekstfeltet."

