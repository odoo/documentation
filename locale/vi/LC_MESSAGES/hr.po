"relevant data."
msgstr ""
"Nhấp :guilabel:`Xuất sang XLSX` để tạo tệp Excel chứa tất cả dữ liệu liên "
"quan."

#: ../../content/applications/hr/payroll/payroll_localizations/belgium.rst:None
msgid "Social Security Certificate PDF Header."
msgstr "Tiêu đề PDF chứng nhận An sinh xã hội."

#: ../../content/applications/hr/payroll/payroll_localizations/belgium.rst:None
