msgstr ""
"SSL-terminointiproxyn tulisi myös automaattisesti ohjata turvattomat "
"yhteydet turvalliseen porttiin"

#: ../../content/administration/on_premise/deploy.rst:277
msgid "Redirect http requests to https"
msgstr "Ohjaa http-pyynnöt https:ään"

#: ../../content/administration/on_premise/deploy.rst:278
msgid "Proxy requests to odoo"
msgstr "Ohjaa pyynnöt Odoolle"

