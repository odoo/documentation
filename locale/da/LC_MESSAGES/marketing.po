msgstr ":icon:`fa-tag` :guilabel:`Mærk varme kontakter`"

#: ../../content/applications/marketing/marketing_automation.rst:0
msgid ""
":guilabel:`Send a welcome email to contacts and tag them if they click it.`"
msgstr ""
":guilabel:`Send en velkomstmail til kontakter og mærk dem, hvis de klikker "
"på den.`"

#: ../../content/applications/marketing/marketing_automation.rst:0
msgid ":icon:`fa-hand-peace-o` :guilabel:`Welcome Flow`"
msgstr ":icon:`fa-hand-peace-o` :guilabel:`Velkomstflow`"

#: ../../content/applications/marketing/marketing_automation.rst:0
msgid ""
":guilabel:`Send a welcome email to new subscribers, remove the address that "
"bounced.`"
msgstr ""
":guilabel:`Send en velkomstmail til nye abonnenter, fjern adressen der "
"bouncede.`"

#: ../../content/applications/marketing/marketing_automation.rst:0
msgid ""
":icon:`fa-check-square` :doc:`Double Opt-in <marketing_automation/"
"campaign_templates/double_optin>`"
msgstr ""
":icon:`fa-check-square` :doc:`Dobbelt opt-in <marketing_automation/"
"campaign_templates/double_optin>`"

#: ../../content/applications/marketing/marketing_automation.rst:0
