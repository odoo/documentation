#: ../../content/applications/general/iot/connect.rst:139
msgid ""
"Click the :icon:`fa-cog` :guilabel:`(Actions)` icon, and "
"select :guilabel:`Delete`."
msgstr ""
"Haz clic en el icono :icon:`fa-cog` :guilabel:`(Acciones)` y "
"selecciona :guilabel:`Eliminar`."

