#: ../../content/applications/sales/crm/performance/win_loss.rst:95
msgid ":guilabel:`Sales Team`: Groups the results by the Sales Team to whom an opportunity is assigned."
msgstr ""

#: ../../content/applications/sales/crm/performance/win_loss.rst:96
msgid ":guilabel:`City`: Groups the results by the city from which an opportunity originated."
msgstr ""

#: ../../content/applications/sales/crm/performance/win_loss.rst:97
msgid ":guilabel:`Country`: Groups the results by the country from which an opportunity originated."
msgstr ""

#: ../../content/applications/sales/crm/performance/win_loss.rst:98
