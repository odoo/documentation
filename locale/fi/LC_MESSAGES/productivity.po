msgstr ":guilabel:`Soittaja poistuu jonosta (agenttia ei yhdistetty)`"

#: ../../content/applications/productivity/voip/axivox/call_queues.rst:131
msgid ":guilabel:`The caller exits the queue (timeout)`"
msgstr ":guilabel:`Soittaja poistuu jonosta (aikakatkaisu)`"

