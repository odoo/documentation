msgid ":doc:`fleet/models`"
msgstr ""

#: ../../content/applications/hr/fleet.rst:86
msgid ":doc:`fleet/new_vehicle`"
msgstr ""

#: ../../content/applications/hr/fleet.rst:87
msgid ":doc:`fleet/service`"
msgstr ""

