msgid ""
"Total = Rule's~Delivery~Cost + (Margin~on~rate \\times Rule's~Delivery~Cost) "
"+ Additional~margin\n"
"\n"
msgstr ""
"Celotno = Strošek~dostave~pravila + (Marža~na~stopnjo \\times "
