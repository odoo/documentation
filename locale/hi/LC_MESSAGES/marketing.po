#: ../../content/applications/marketing/marketing_automation/target_audience.rst:67
msgid ":guilabel:`Stage` :guilabel:`is in` :guilabel:`New`"
msgstr ":guilabel:`स्टेज` :guilabel:`इसमें है` :guilabel:`नया`"

