#: ../../content/applications/productivity/spreadsheet/visualize_data/conditional_formatting.rst:147
#: ../../content/applications/productivity/spreadsheet/work_with_data/global_filters.rst:138
#: ../../content/applications/productivity/spreadsheet/work_with_data/global_filters.rst:181
#: ../../content/applications/productivity/spreadsheet/work_with_data/global_filters.rst:214
