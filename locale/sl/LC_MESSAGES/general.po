msgstr ""
":abbr:`MRP (Material Requirement Planning)` naprave, vključno s kamerami in "
"merilnimi orodji, niso združljive z Windows virtual IoT."

#: ../../content/applications/general/iot.rst:22
msgid "Multiple IoT systems can be used at the same time."
msgstr "Več sistemov IoT je mogoče uporabljati hkrati."

#: ../../content/applications/general/iot.rst:23
#: ../../content/applications/general/iot/windows_iot.rst:27
msgid ""
