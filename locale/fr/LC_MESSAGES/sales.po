msgstr ":guilabel:`name` : Référence de la commande"

#: ../../content/applications/sales/sales/sales_quotations/pdf_quote_builder/dynamic_text.rst:191
msgid ":guilabel:`partner_id__name`: Customer Name"
msgstr ":guilabel:`partner_id__name` : Nom du client"

#: ../../content/applications/sales/sales/sales_quotations/pdf_quote_builder/dynamic_text.rst:192
msgid ":guilabel:`user_id__name`: Salesperson Name"
