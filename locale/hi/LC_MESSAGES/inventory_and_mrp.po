msgstr ""
"जगह पर ओवरस्टॉकिंग को रोकने और उचित व्यवस्था सुनिश्चित करने के लिए आइटम या वजन की "
"सीमा सेट करें"

#: ../../content/applications/inventory_and_mrp/inventory/shipping_receiving/daily_operations.rst:105
msgid "Consignment"
msgstr "कंसाइनमेंट"

#: ../../content/applications/inventory_and_mrp/inventory/shipping_receiving/daily_operations.rst:105
