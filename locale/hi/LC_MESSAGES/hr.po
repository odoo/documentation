#: ../../content/applications/hr/payroll/payroll_localizations/australia.rst:None
msgid "Importing YTD balances."
msgstr "YTD बैलेंस इम्पोर्ट करना।"

#: ../../content/applications/hr/payroll/payroll_localizations/australia.rst:477
