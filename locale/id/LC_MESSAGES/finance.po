#: ../../content/applications/finance/fiscal_localizations/philippines.rst:174
msgid ""
"Go to :menuselection:`Accounting --> Vendors --> Bills` and select one or "
"multiple vendor bills from the list view."
msgstr ""
"Buka :menuselection:`Akuntansi --> Vendor --> Bills` dan pilih satu atau "
