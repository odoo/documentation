#: ../../content/applications/sales/point_of_sale/extra/preparation.rst:70
msgid ""
"The :guilabel:`Average time` employees usually take to complete an order."
msgstr ":guilabel:`औसत समय` जो कर्मचारी आमतौर पर एक ऑर्डर पूरा करने में लेते हैं।"

#: ../../content/applications/sales/point_of_sale/extra/preparation.rst:71
msgid ""
"The :ref:`Order Status Screen <preparation/order-status-screen>` button."
msgstr ":ref:`ऑर्डर स्टेटस स्क्रीन <preparation/order-status-screen>` बटन।"

#: ../../content/applications/sales/point_of_sale/extra/preparation.rst:74
msgid ""
"A default preparation display named :guilabel:`Kitchen Display` is "
