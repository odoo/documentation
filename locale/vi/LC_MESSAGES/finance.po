#: ../../content/applications/finance/fiscal_localizations/brazil.rst:737
msgid ""
"The following are mandatory fields to issue a CPF/CNPJ identified NFC-e:"
msgstr "Sau đây là các trường bắt buộc để phát hành NFC-e có CPF/CNPJ:"

#: ../../content/applications/finance/fiscal_localizations/brazil.rst:740
msgid ""
":guilabel:`City` and :guilabel:`State` where the invoice is being issued"
msgstr ":guilabel:`City` và :guilabel:`State` nơi hóa đơn đang được phát hành"

#: ../../content/applications/finance/fiscal_localizations/brazil.rst:741
msgid ":guilabel:`CPF/CNPJ`"
