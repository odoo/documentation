#: ../../content/applications/finance/fiscal_localizations/jordan.rst:221
msgid "Navigate to :guilabel:`More`."
msgstr "Naviguer vers :guilabel:`Plus`."

#: ../../content/applications/finance/fiscal_localizations/jordan.rst:222
