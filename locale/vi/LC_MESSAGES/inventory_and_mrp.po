#: ../../content/applications/inventory_and_mrp/inventory/warehouses_storage/replenishment/reordering_rules.rst:109
msgid ":guilabel:`Product`: The product that is replenished by the rule."
msgstr ":guilabel:`Sản phẩm`: Sản phẩm được bổ sung bởi quy tắc này."

#: ../../content/applications/inventory_and_mrp/inventory/warehouses_storage/replenishment/reordering_rules.rst:110
msgid ":guilabel:`Location`: The location where the product is stored."
msgstr ":guilabel:`Vị trí`: vị trí lưu trữ sản phẩm."

#: ../../content/applications/inventory_and_mrp/inventory/warehouses_storage/replenishment/reordering_rules.rst:111
msgid ""
":guilabel:`Min`: The minimum quantity that can be forecasted without the "
"rule being triggered. When forecasted stock falls below this number, a "
"replenishment order for the product is created."
msgstr ""
