msgstr "Tukaj je seznam razpoložljivih belgijskih specifičnih poročil:"

#: ../../content/applications/finance/fiscal_localizations/belgium.rst:93
msgid "Balance sheet;"
msgstr "Bilanca stanja;"

#: ../../content/applications/finance/fiscal_localizations/belgium.rst:94
msgid "Profit & loss;"
msgstr "Izkaz poslovnega izida;"

#: ../../content/applications/finance/fiscal_localizations/belgium.rst:95
msgid "Tax report;"
msgstr "Davčno poročilo;"

#: ../../content/applications/finance/fiscal_localizations/belgium.rst:96
