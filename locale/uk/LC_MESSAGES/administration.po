#: ../../content/administration/on_premise/source.rst:521
#: ../../content/administration/on_premise/source.rst:584
msgid "Windows"
msgstr "Windows"

#: ../../content/administration/on_premise/deploy.rst:777
msgid ""
"The configuration file is located at: `c:\\\\ProgramFiles\\\\Odoo{VERSION}\\"
"\\server\\\\odoo.conf`"
msgstr ""
"Конфігураційний файл розташований за адресою: `c:\\\\ProgramFiles\\"
"\\Odoo{VERSION}\\\\server\\\\odoo.conf`"

#: ../../content/administration/on_premise/deploy.rst:779
#: ../../content/administration/on_premise/packages.rst:25
