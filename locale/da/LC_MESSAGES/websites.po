#: ../../content/applications/websites/website/structure/header_footer.rst:188
msgid "Choose the :guilabel:`Border` size."
msgstr "Zvolte velikost :guilabel:`Ohraničení`."

#: ../../content/applications/websites/website/structure/header_footer.rst:189
