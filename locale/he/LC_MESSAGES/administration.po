msgstr ""
"לאחר מכן השתמש בספרייה במודול שלך, למשל כדי להסיר הטעמות מתווים בשדה השם של "
"המודל שלך."

#: ../../content/administration/odoo_sh/first_module.rst:458
msgid "Open the file *models/models.py*."
msgstr "פתח את הקובץ *models/models.py*."

