msgstr "Sao kê"

#: ../../content/applications/finance/accounting.rst:193
#: ../../content/applications/finance/accounting/customer_invoices.rst:173
msgid "Balance sheet"
msgstr "Bảng cân đối kế toán"

#: ../../content/applications/finance/accounting.rst:195
