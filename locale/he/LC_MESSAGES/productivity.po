msgid "Returns the value from a list (not compatible with Excel)"
msgstr "מחזירה את הערך מרשימה (לא תואם ל-Excel)"

#: ../../content/applications/productivity/spreadsheet/work_with_data/functions.rst:992
msgid "ODOO.LIST.HEADER(list_id, field_name)"
msgstr "ODOO.LIST.HEADER(list_id, field_name)"

