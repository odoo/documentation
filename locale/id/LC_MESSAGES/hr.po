#: ../../content/applications/hr/payroll/payroll_localizations/hong_kong.rst:29
msgid ""
":guilabel:`Autopay "
"Type`: :guilabel:`BBAN`, :guilabel:`SVID`, :guilabel:`EMAL`, etc."
msgstr ""
":guilabel:`Jenis Autopay`: :guilabel:`BBAN`, :guilabel:`SVID`, "
