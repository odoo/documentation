msgstr ""

#: ../../content/applications/sales/crm/performance/win_loss.rst:148
msgid ":guilabel:`Prorated MRR`: Measures the prorated monthly recurring revenue of an opportunity."
msgstr ""

#: ../../content/applications/sales/crm/performance/win_loss.rst:149
msgid ":guilabel:`Prorated Recurring Revenues`: Measures the prorated recurring revenues of an opportunity."
msgstr ""

#: ../../content/applications/sales/crm/performance/win_loss.rst:151
