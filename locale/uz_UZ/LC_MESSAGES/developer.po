msgstr "Mavjud shablonlarni o'z joyida o'zgartirish, masalan shablonlarga ma'lumot qo'shish"

#: ../../content/developer/reference/frontend/qweb.rst:561
msgid "created by other modules."
msgstr "boshqa modullar tomonidan yaratilgan."

#: ../../content/developer/reference/frontend/qweb.rst:561
msgid "Create a new template from a given parent template"
msgstr "Berilgan ota shablondan yangi shablon yaratish"

