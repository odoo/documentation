#: ../../content/applications/finance/fiscal_localizations/france.rst:578
msgid ""
":guilabel:`Nom de l'utilisateur`: User name associated with the Odoo account."
msgstr ""
":guilabel:`Nom de l'utilisateur`: имя пользователя, связанное с учетной "
