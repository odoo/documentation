msgid "Used for"
msgstr "Uporabljeno za"

#: ../../content/applications/finance/fiscal_localizations/united_states.rst:1085
msgid "Global & cross-border payments"
msgstr "Globalna in čezmejna plačila"

#: ../../content/applications/finance/fiscal_localizations/united_states.rst:1086
msgid "Domestic U.S. payments"
msgstr "Domača plačila v ZDA"

#: ../../content/applications/finance/fiscal_localizations/united_states.rst:1088
msgid "XML-based standard"
