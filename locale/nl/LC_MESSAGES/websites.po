"instellingenpagina."

#: ../../content/applications/websites/website/configuration/multi_website.rst:None
msgid "Selecting a website in the app settings"
msgstr "Een website selecteren in de app-instellingen"

#: ../../content/applications/websites/website/configuration/multi_website.rst:51
msgid ""
"Settings shared by all websites are indicated using the :icon:`fa-info-"
