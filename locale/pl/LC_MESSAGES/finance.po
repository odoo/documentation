msgstr "Kliknij ikonę :icon:`fa-cog` :guilabel:`(koło zębate)`"

#: ../../content/applications/finance/fiscal_localizations/malaysia.rst:328
msgid "Select :guilabel:`Download`"
msgstr "Wybierz :guilabel:`Pobierz`"

#: ../../content/applications/finance/fiscal_localizations/malaysia.rst:329
msgid "Choose either :guilabel:`PDF` or :guilabel:`PDF without Payment`"
msgstr "Wybierz :guilabel:`PDF` lub :guilabel:`PDF bez płatności`"

