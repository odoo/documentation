msgid "Process batch transfers"
msgstr "Xử lý chuyển kho theo lô"

#: ../../content/applications/inventory_and_mrp/barcode/operations/process_transfers.rst:5
msgid ""
"The Odoo **Barcode** app can be used to process *Batch*, *Wave*, and "
"*Cluster* transfers that are created in the **Inventory** app."
msgstr ""
"Ứng dụng **Mã vạch** của Odoo có thể được sử dụng để xử lý các lần chuyển "
