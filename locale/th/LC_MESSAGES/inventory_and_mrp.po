msgid ":doc:`Manual reservation <manually>`"
msgstr ":doc:`การจองแบบแมนนวล <manually>`"

#: ../../content/applications/inventory_and_mrp/inventory/shipping_receiving/reservation_methods/at_confirmation.rst:90
