msgstr "modulning odam o'qiy oladigan nomi"

#: ../../content/developer/reference/backend/module.rst:44
msgid "``version`` (``str``)"
msgstr "``version`` (``str``)"

#: ../../content/developer/reference/backend/module.rst:45
