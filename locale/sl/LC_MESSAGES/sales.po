msgid "SKU reference"
msgstr "SKU referenca"

#: ../../content/applications/sales/sales/lazada_connector/features.rst:20
#: ../../content/applications/sales/sales/shopee_connector.rst:20
msgid "Quantity"
msgstr "Količina"

#: ../../content/applications/sales/sales/lazada_connector/features.rst:22
msgid ""
"Synchronize (Odoo to Lazada) all available product quantities (:abbr:`FBM "
"(Fulfilled By Merchant)`)."
msgstr ""
"Sinhronizacija (Odoo v Lazada) vseh razpoložljivih količin izdelkov "
"(:abbr:`FBM (Fulfilled By Merchant)`)."

#: ../../content/applications/sales/sales/lazada_connector/features.rst:25
msgid ""
"Synchronize the Lazada product catalog into Odoo or map existing Odoo "
"products to Lazada SKUs."
msgstr ""
"Sinhronizacija kataloga izdelkov Lazada v Odoo ali preslikava obstoječih "
"izdelkov Odoo na Lazada SKU."

