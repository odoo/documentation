#: ../../content/applications/hr/lunch/vendors.rst:48
msgid ":guilabel:`Email`: enter the vendor's email."
msgstr ""

#: ../../content/applications/hr/lunch/vendors.rst:49
msgid ":guilabel:`Phone`: enter the vendor's phone number."
