#: ../../content/applications/productivity/spreadsheet/work_with_data/pivot_tables.rst:273
msgid "By dimension value"
msgstr ""

#: ../../content/applications/productivity/spreadsheet/work_with_data/pivot_tables.rst:275
msgid ""
"Dimension values are typically sorted in ascending alphabetical, "
"chronological, or numerical order by default."
msgstr ""

#: ../../content/applications/productivity/spreadsheet/work_with_data/pivot_tables.rst:278
msgid "To change how a dimension is sorted by dimension value:"
msgstr ""

#: ../../content/applications/productivity/spreadsheet/work_with_data/pivot_tables.rst:280
