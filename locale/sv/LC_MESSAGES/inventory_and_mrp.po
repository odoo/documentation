msgstr ""
":guilabel:`Öppna leveranser till dagens datum`: visar antalet öppna "
"leveranser per ansvarig användare."

#: ../../content/applications/inventory_and_mrp/inventory/warehouses_storage/reporting/dashboards.rst:84
msgid ""
