#: ../../content/applications/inventory_and_mrp/inventory/inventory_valuation/scrapped_inventory_valuation.rst:18
msgid ":ref:`Scrap products <inventory/inventory_valuation/scrap-products>`."
msgstr ""
":ref:`Skrota produkter <inventory/inventory_valuation/scrap-products>`."

#: ../../content/applications/inventory_and_mrp/inventory/inventory_valuation/scrapped_inventory_valuation.rst:19
msgid ""
":ref:`View scrapped products in the Profit and Loss report <inventory/"
"inventory_valuation/view-profit-loss>`."
msgstr ""
":ref:`Visa skrotade produkter i Resultaträkningen <inventory/"
