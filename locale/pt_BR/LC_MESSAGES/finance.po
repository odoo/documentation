#: ../../content/applications/finance/fiscal_localizations/france.rst:557
msgid ""
"The :guilabel:`Etat` (Status) column shows the progress of the document "
"filing."
msgstr ""
"A coluna :guilabel:`Etat` (Status) mostra o progresso do arquivamento do "
