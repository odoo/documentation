msgstr ":guilabel:`完成交易所需天數`"

#: ../../content/applications/sales/crm/optimize/gamification.rst:133
msgid ":guilabel:`New Opportunities`"
msgstr ":guilabel:`新商機`"

#: ../../content/applications/sales/crm/optimize/gamification.rst:134
