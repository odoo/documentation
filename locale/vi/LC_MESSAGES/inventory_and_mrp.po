#: ../../content/applications/inventory_and_mrp/inventory/shipping_receiving/setup_configuration/new_delivery_method.rst:198
msgid "Routes form with the :guilabel:`Shipping Method` checkbox ticked."
msgstr ""
"Biểu mẫu tuyến với hộp kiểm :guilabel:`Phương thức Vận chuyển` được đánh dấu."

#: ../../content/applications/inventory_and_mrp/inventory/shipping_receiving/setup_configuration/new_delivery_method.rst:200
