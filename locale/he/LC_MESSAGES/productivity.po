#: ../../content/applications/productivity/sign/validity/algeria.rst:11
msgid "Legal framework for electronic signatures in Algeria"
msgstr "מסגרת חוקית לחתימות אלקטרוניות באלג'יריה"

#: ../../content/applications/productivity/sign/validity/algeria.rst:13
msgid ""
