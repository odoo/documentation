msgstr ":guilabel:`Adresse du siège social`: Endereço da sede."

#: ../../content/applications/finance/fiscal_localizations/france.rst:545
msgid ":guilabel:`Nom du représentant légal`: Legal representative's name."
msgstr ":guilabel:`Nom du représentant légal`: Nome do representante legal."

#: ../../content/applications/finance/fiscal_localizations/france.rst:546
