#: ../../content/applications/finance/fiscal_localizations/luxembourg.rst:62
msgid ""
"standard VAT (17%): applied to most goods and services within Luxembourg"
msgstr ""
"IVA standard (17%): applicata alla maggior parte di beni e servizi in "
"Lussemburgo"

#: ../../content/applications/finance/fiscal_localizations/luxembourg.rst:63
