#~ "marketing budget."

#~ msgid ""
#~ "Go to :menuselection:`Website --> Configuration --> Settings` and "
#~ "activate *Link Trackers*."
#~ msgstr ""
#~ "Gå til :menuselection:`Hjemmeside --> Konfiguration --> Indstillinger`og "
#~ "aktiver *Link sporere*."

#~ msgid "Set up traceable URLs"
#~ msgstr "Opsæt sporbare URL'er"

#~ msgid ""
#~ "Go to :menuselection:`Website --> Go to website --> Promote --> Track "
