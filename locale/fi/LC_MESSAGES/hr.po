msgstr ""
"Vaihda nykyisen henkilöstön ja entisten työntekijöiden välillä "
"tarkasteltaessa historiallisia tietoja."

#: ../../content/applications/hr/attendances.rst:214
msgid "Insightful groupings"
msgstr "Oivaltavat ryhmittelyt"

#: ../../content/applications/hr/attendances.rst:221
msgid "Group by"
msgstr "Ryhmittele"

#: ../../content/applications/hr/attendances.rst:222
