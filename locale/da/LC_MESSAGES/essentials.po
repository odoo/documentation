#: ../../content/applications/essentials/export_import_data.rst:394
msgid ""
":download:`Purchase orders with their respective purchase order lines "
"<export_import_data/o2m-purchase-order-lines.csv>`"
msgstr ""
":download:`Indkøbsordrer med deres respektive indkøbsordrelinjer "
"<export_import_data/o2m-purchase-order-lines.csv>`"

#: ../../content/applications/essentials/export_import_data.rst:397
msgid ""
"A company imports customers and their respective contacts using a :abbr:`CSV "
"(Comma-separated Values)` file:"
msgstr ""
"En virksomhed importerer kunder og deres respektive kontakter ved hjælp af "
