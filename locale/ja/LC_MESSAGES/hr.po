#: ../../content/applications/hr/fleet/service.rst:None
msgid ""
"The oil change service records showing only repairs with past-due activities."
msgstr ""

#: ../../content/applications/hr/fleet/service.rst:369
msgid "Schedule activities"
msgstr "活動をスケジュールする"

