msgstr ":guilabel:`Udbyder`: vælg :guilabel:`Axivox`."

#: ../../content/applications/productivity/phone/axivox/axivox_config.rst:65
msgid ":guilabel:`Username`: the Axivox :guilabel:`SIP username`."
msgstr ":guilabel:`Brugernavn`: Axivox :guilabel:`SIP-brugernavn`."

#: ../../content/applications/productivity/phone/axivox/axivox_config.rst:66
msgid ":guilabel:`OnSip Auth Username`: the Axivox :guilabel:`SIP username`."
msgstr ":guilabel:`OnSip Auth-brugernavn`: Axivox :guilabel:`SIP-brugernavn`."

#: ../../content/applications/productivity/phone/axivox/axivox_config.rst:67
