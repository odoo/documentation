#: ../../content/applications/finance/fiscal_localizations/ecuador.rst:662
msgid ":guilabel:`Payment Method (SRI)`: Select a payment method."
msgstr ":guilabel:`Metoda płatności (SRI)`: Wybierz metodę płatności."

