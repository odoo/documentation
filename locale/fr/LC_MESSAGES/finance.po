msgstr "Pour configurer un compte Uruware, suivez ces étapes :"

#: ../../content/applications/finance/fiscal_localizations/uruguay.rst:114
msgid "Verify that you have a valid Odoo subscription."
msgstr "Vérifiez que vous disposez d'un abonnement Odoo valide."

#: ../../content/applications/finance/fiscal_localizations/uruguay.rst:115
msgid ""
"Locate the Uruware credentials settings by navigating to "
"the :menuselection:`Accounting --> Configuration --> Settings`."
msgstr ""
