msgid "Odoo sends a notification to DIAN."
msgstr "Odoo sender en meddelelse til DIAN."

#: ../../content/applications/finance/fiscal_localizations/colombia.rst:321
msgid "|DIAN| validates the invoice."
msgstr "|DIAN| validerer fakturaen."

#: ../../content/applications/finance/fiscal_localizations/colombia.rst:322
