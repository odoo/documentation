msgstr ""

#: ../../content/applications/marketing/events/event_setup/create_events.rst:208
msgid ":guilabel:`Before the event starts`"
msgstr ""

#: ../../content/applications/marketing/events/event_setup/create_events.rst:209
msgid ":guilabel:`After the event started`"
msgstr ""

#: ../../content/applications/marketing/events/event_setup/create_events.rst:210
