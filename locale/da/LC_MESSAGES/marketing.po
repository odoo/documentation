msgstr ":ref:`Noter <events/event-notes>`"

#: ../../content/applications/marketing/events/event_templates.rst:121
msgid "Booths tab"
msgstr "Fanen Stande"

#: ../../content/applications/marketing/events/event_templates.rst:123
