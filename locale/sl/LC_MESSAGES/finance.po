msgstr "Popolna primerjava"

#: ../../content/applications/finance/fiscal_localizations/france.rst:337
msgid "3-digits comparison"
msgstr "Primerjava 3 števk"

#: ../../content/applications/finance/fiscal_localizations/france.rst:337
