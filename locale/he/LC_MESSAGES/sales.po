#: ../../content/applications/sales/crm/performance/win_loss.rst:381
msgid ":guilabel:`Export All`: downloads the list as an xlsx file for Excel."
msgstr ":guilabel:`ייצוא הכל`: מוריד את הרשימה כקובץ xlsx עבור Excel."

