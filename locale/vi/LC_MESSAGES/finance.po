#: ../../content/applications/finance/accounting/customer_invoices/payment_terms.rst:184
msgid ""
"The $1000 debited to the account receivable is split into two distinct "
"journal items. Both of them have their own due date."
msgstr ""
"Số tiền $1000 ghi nợ vào tài khoản phải thu được tách thành hai bút toán "
