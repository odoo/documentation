msgid "Azure Interior"
msgstr "Azure Interior"

#: ../../content/applications/productivity/whatsapp.rst:737
#: ../../content/applications/productivity/whatsapp.rst:741
#: ../../content/applications/productivity/whatsapp.rst:745
