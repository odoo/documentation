msgstr "ग्राहकों को कोटेशन बनाएं, कॉन्फ़िगर करें और भेजें।"

#: ../../content/applications/sales/sales/sales_quotations.rst:47
#: ../../content/applications/sales/sales/sales_quotations/optional_products.rst:72
#: ../../content/applications/sales/sales/sales_quotations/quote_template.rst:3
msgid "Quotation templates"
msgstr "कोटेशन टेम्प्लेट"

#: ../../content/applications/sales/sales/sales_quotations.rst:47
msgid ""
"Configure and use quotation templates to send tailor-fit quotations at a "
