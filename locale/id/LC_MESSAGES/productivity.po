msgstr "Memasukkan tabel pivot yang mengambil data Odoo dari spreadsheet"

#: ../../content/applications/productivity/spreadsheet/insert/insert_pivot_table.rst:241
msgid ""
"To insert a pivot table using Odoo data directly from an Odoo spreadsheet:"
msgstr ""
"Untuk memasukkan tabel pivot menggunakan data Odoo langsung dari spreadsheet "
