#: ../../content/applications/finance/fiscal_localizations/brazil.rst:441
msgid "Tax calculations on invoices"
msgstr "Calculs des taxes sur les factures"

#: ../../content/applications/finance/fiscal_localizations/brazil.rst:443
msgid ""
"Trigger an |API| call to calculate taxes on a customer invoice automatically "
"with AvaTax in any of the following ways:"
msgstr ""
"Déclencher un appel |API| pour calculer automatiquement les taxes sur une "
"facture client avec AvaTax de l'une des manières suivantes :"

