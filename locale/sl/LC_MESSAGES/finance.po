msgstr "Popustno ujemanje: za plačilne pogoje s popusti za zgodnja plačila"

#: ../../content/applications/finance/accounting/bank/reconciliation.rst:129
msgid ""
"Amount in label: if the invoice :guilabel:`Amount` is found in the "
"transaction's :guilabel:`Label`"
