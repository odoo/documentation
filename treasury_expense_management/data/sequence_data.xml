<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Custody Sequence -->
        <record id="seq_treasury_custody" model="ir.sequence">
            <field name="name">عهدة</field>
            <field name="code">treasury.custody</field>
            <field name="prefix">CUS/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

        <!-- Vendor Payment Claim Sequence -->
        <record id="seq_payment_claim_vendor" model="ir.sequence">
            <field name="name">مطالبة مورد</field>
            <field name="code">treasury.payment.claim.vendor</field>
            <field name="prefix">VPC/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

        <!-- Expense Claim Sequence -->
        <record id="seq_payment_claim_expense" model="ir.sequence">
            <field name="name">مطالبة مصاريف</field>
            <field name="code">treasury.payment.claim.expense</field>
            <field name="prefix">EXP/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

        <!-- Outbound Payment Sequence -->
        <record id="seq_claim_payment_out" model="ir.sequence">
            <field name="name">سند صرف</field>
            <field name="code">treasury.claim.payment.outbound</field>
            <field name="prefix">PMT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

        <!-- Inbound Payment Sequence -->
        <record id="seq_claim_payment_in" model="ir.sequence">
            <field name="name">سند قبض</field>
            <field name="code">treasury.claim.payment.inbound</field>
            <field name="prefix">RCV/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

    </data>
</odoo>
