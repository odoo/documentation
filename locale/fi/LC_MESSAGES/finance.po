"ose#:~:text=El%20Operador%20de%20Servicios%20Electr%C3%B3nicos%20(OSE)"
"%20es%20qui%C3%A9n%20se%20encarga,otro%20documento%20que%20se%20emita>`_."
msgstr ""
"**OSE**: Electronic Service Operator, `OSE SUNAT:n määritelmä <https://"
"cpe.sunat.gob.pe/aliados/"
"ose#:~:text=El%20Operador%20de%20Servicios%20Electr%C3%B3nicos%20(OSE)"
"%20es%20qui%C3%A9n%20se%20encarga,otro%20documento%20que%20se%20emita>`_."

#: ../../content/applications/finance/fiscal_localizations/peru.rst:152
msgid "**CDR**: Receipt certificate (Constancia de Recepción)."
msgstr "**CDR**: Vastaanottotodistus (Constancia de Recepción)."

#: ../../content/applications/finance/fiscal_localizations/peru.rst:153
msgid ""
"**SOL Credentials**: Sunat Operaciones en Línea. User and password are "
