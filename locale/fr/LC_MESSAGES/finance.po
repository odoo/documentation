#: ../../content/applications/finance/fiscal_localizations/luxembourg.rst:234
msgid ""
"You then need to manually complete appendices B through G, as well as the "
"Appendix to Operational Expenditures, with any additional information to be "
"reported."
msgstr ""
"Compléter ensuite manuellement les annexes B à G, ainsi que l'annexe aux "
"dépenses opérationnelles, avec toute information supplémentaire à déclarer."

#: ../../content/applications/finance/fiscal_localizations/luxembourg.rst:238
msgid "Exporting the declaration"
msgstr "Exporter la déclaration"

#: ../../content/applications/finance/fiscal_localizations/luxembourg.rst:240
