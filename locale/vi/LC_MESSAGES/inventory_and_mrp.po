msgstr ""
"*Vị trí lưu trữ* cho phép sản phẩm được lưu trữ tại các vị trí cụ thể mà "
"chúng có thể được lấy ra, trong khi *tuyến đường nhiều bước* cho phép hoạt "
"động lấy hàng."

#: ../../content/applications/inventory_and_mrp/inventory/shipping_receiving/picking_methods/cluster.rst:64
msgid "When finished, click :guilabel:`Save`."
msgstr "Khi hoàn tất, nhấp vào :guilabel:`Lưu`."

