#: ../../content/applications/finance/fiscal_localizations/brazil.rst:749
msgid "NFC-e ticket print"
msgstr "In phiếu NFC-e"

#: ../../content/applications/finance/fiscal_localizations/brazil.rst:751
msgid ""
"After :ref:`generating and validating the NFC-e <localizations/brazil/"
"generate-nfc-e>`, click :guilabel:`Print` to deliver the invoice."
msgstr ""
"Sau khi :ref:`tạo và xác thực NFC-e <localizations/brazil/generate-nfc-e>`, "
"nhấp vào :guilabel:`Print` để gửi hóa đơn."

#: ../../content/applications/finance/fiscal_localizations/brazil.rst:755
msgid ""
"The Odoo NFC-e feature is compatible with any thermal printer and does not "
