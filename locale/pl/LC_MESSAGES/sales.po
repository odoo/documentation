msgid "Scribus_"
msgstr "Scribus_"

#: ../../content/applications/sales/sales/sales_quotations/pdf_quote_builder/dynamic_text.rst:54
msgid "BentoPDF_"
msgstr "BentoPDF_"

#: ../../content/applications/sales/sales/sales_quotations/pdf_quote_builder/dynamic_text.rst:55
msgid "EmbedPDF_"
msgstr "EmbedPDF_"

#: ../../content/applications/sales/sales/sales_quotations/pdf_quote_builder/dynamic_text.rst:57
