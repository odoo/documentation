msgstr ""
":guilabel:`Palkkarakennetyyppi`: aseta :guilabel:`CAP57: Hong Kong Employee`."

#: ../../content/applications/hr/payroll/payroll_localizations/hong_kong.rst:68
msgid ":guilabel:`Contract Start Date`: start date of employment."
msgstr ":guilabel:`Sopimuksen alkamispäivä`: työsuhteen alkamispäivä."

