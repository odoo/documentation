msgid "Set the :guilabel:`Active` dropdown menu to :guilabel:`Paid`."
msgstr "Встановіть спадне меню :guilabel:`Активні` на :guilabel:`Оплачені`."

#: ../../content/applications/sales/point_of_sale/use/pos_invoices.rst:72
msgid ""
"Select the relevant order and click :icon:`fa-file-pdf-"
