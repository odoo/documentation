msgstr ""
":guilabel:`Kategorija`: združi zapise po kategoriji izdelka. Za "
"konfiguracijo pojdite na :menuselection:`Zaloga --> Konfiguracija --> "
"Izdelki: Kategorije izdelkov`."

#: ../../content/applications/inventory_and_mrp/inventory/warehouses_storage/reporting/moves_history.rst:84
msgid ""
