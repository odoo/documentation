msgid "Product units"
msgstr "Одиниці продуктів"

#: ../../content/applications/sales/point_of_sale/products.rst:183
msgid ""
"Products can be grouped by :doc:`unit of measure </applications/"
"inventory_and_mrp/inventory/product_management/configure/uom>` in "
"the :ref:`POS register <pos/use/open-register>` and on the :doc:`customer "
