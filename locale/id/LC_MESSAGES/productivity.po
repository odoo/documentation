msgstr ":guilabel:`Jenis media yang diizinkan`: `SRTP-DTLS`"

#: ../../content/applications/productivity/voip/didww.rst:54
msgid ":guilabel:`Default media type`: `SRTP-DTLS`"
msgstr ":guilabel:`Jenis media default`: `SRTP-DTLS`"

