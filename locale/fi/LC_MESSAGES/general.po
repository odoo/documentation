msgid "Windows virtual IoT homepage"
msgstr "Windows virtual IoT -kotisivu"

#: ../../content/applications/general/iot/windows_iot.rst:132
msgid ""
"To access the Windows virtual IoT's homepage, navigate to the URL `http://"
