msgstr "To lots, der reserveres til en salgsordre med FIFO-strategien."

#: ../../content/applications/inventory_and_mrp/inventory/shipping_receiving/removal_strategies/fifo.rst:156
msgid ""
":ref:`Lot/serial number setup details <inventory/warehouses_storage/lots-"
"setup>`"
msgstr ""
":ref:`Detaljer om opsætning af lot/serienummer <inventory/warehouses_storage/"
