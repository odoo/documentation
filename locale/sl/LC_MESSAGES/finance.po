#: ../../content/applications/finance/fiscal_localizations/turkiye.rst:383
msgid "Upload e-Dispatch files"
msgstr "Naloži datoteke e-Dispatch"

#: ../../content/applications/finance/fiscal_localizations/turkiye.rst:385
