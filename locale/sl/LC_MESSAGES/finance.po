msgstr ":ref:`Računovodstvo <esg/accounting>`"

#: ../../content/applications/finance/esg.rst:32
msgid ":ref:`Fleet <esg/fleet>`"
msgstr ":ref:`Vozni park <esg/fleet>`"

#: ../../content/applications/finance/esg.rst:33
