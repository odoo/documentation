msgstr ":doc:`העברת אשראי SEPA <sepa_payments>`"

#: ../../content/applications/finance/accounting/payments/batch.rst:41
msgid ":doc:`SEPA Direct Debit <sepa_payments>`"
msgstr ":doc:`חיוב ישיר SEPA <sepa_payments>`"

#: ../../content/applications/finance/accounting/payments/batch.rst:42
msgid ":doc:`SEPA Payments for Payroll <../../../hr/payroll>`"
msgstr ":doc:`תשלומי SEPA עבור שכר <../../../hr/payroll>`"

#: ../../content/applications/finance/accounting/payments/batch.rst:43
