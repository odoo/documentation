msgid ":doc:`../reporting/intrastat`"
msgstr ":doc:`../reporting/intrastat`"

#: ../../content/applications/finance/accounting/customer_invoices/incoterms.rst:29
msgid ":doc:`../customer_invoices`"
msgstr ":doc:`../customer_invoices`"

