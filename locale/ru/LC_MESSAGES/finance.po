#: ../../content/applications/finance/fiscal_localizations/peru.rst:851
msgid ":guilabel:`Transport Type`"
msgstr ":guilabel:`Тип транспорта`"

#: ../../content/applications/finance/fiscal_localizations/peru.rst:852
msgid ":guilabel:`Reason for Transfer`"
msgstr ":guilabel:`Причина перемещения`"

#: ../../content/applications/finance/fiscal_localizations/peru.rst:853
msgid ":guilabel:`Departure start date`"
msgstr ":guilabel:`Дата начала отправки`"

#: ../../content/applications/finance/fiscal_localizations/peru.rst:855
msgid ""
"It is also required to complete the :guilabel:`Vehicle` "
"and :guilabel:`Operator` fields under the :guilabel:`Guia de Remision PE` "
