msgstr "Maydonni progress bar sifatida ko'rsating"

#: ../../content/developer/tutorials/backend.rst:723
#: ../../content/developer/tutorials/importable_modules.rst:249
msgid "Default values"
msgstr "Standart qiymatlar"

#: ../../content/developer/tutorials/backend.rst:725
msgid ""
"Any field can be given a default value. In the field definition, add the "
