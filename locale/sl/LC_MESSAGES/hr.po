msgstr ""
"Pojdite na :menuselection:`Plačni seznam --> Poročanje --> Belgija --> "
"Potrdilo o socialnem zavarovanju`."

#: ../../content/applications/hr/payroll/payroll_localizations/belgium.rst:2485
