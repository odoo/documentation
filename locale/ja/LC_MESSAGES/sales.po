#: ../../content/applications/sales/point_of_sale/use.rst:336
#: ../../content/applications/sales/point_of_sale/use.rst:356
msgid "Click :guilabel:`Apply`."
msgstr ":guilabel:`適用`\\ をクリックします。"

#: ../../content/applications/sales/point_of_sale/use.rst:341
msgid "Customer notes"
msgstr "顧客メモ"

#: ../../content/applications/sales/point_of_sale/use.rst:343
msgid ""
"Customer notes appear on :doc:`receipts <use/receipts>` and :doc:`invoices "
"<use/pos_invoices>`. They can be used, for example, to provide warranty "
"details for a high-value item or specific care instructions, such as `Dry "
