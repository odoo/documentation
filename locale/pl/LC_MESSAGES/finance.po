msgid ":guilabel:`Journal`: :guilabel:`Bank`"
msgstr ":guilabel:`Dziennik`: :guilabel:`Bank`"

#: ../../content/applications/finance/fiscal_localizations/australia.rst:467
msgid ":guilabel:`Payment Method`: :guilabel:`ABA Credit Transfer`"
msgstr ":guilabel:`Metoda płatności`: :guilabel:`Przelew kredytowy ABA`"

