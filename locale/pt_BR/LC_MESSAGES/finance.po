msgid ""
"Avalara's support documents: `About AvaTax <https://community.avalara.com/"
"support/s/document-item?language=en_US>`_"
msgstr ""
"Documentos de suporte da Avalara: `Sobre o AvaTax <https://"
"community.avalara.com/support/s/document-item?language=en_US>`_"

