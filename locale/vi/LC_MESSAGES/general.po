"nhưng giá trị vẫn giữ nguyên:"

#: ../../content/applications/general/email_communication/email_domain.rst:114
msgid "Example CNAME record with custom domain"
msgstr "Ví dụ bản ghi CNAME với tên miền tùy chỉnh"

