#: ../../content/applications/finance/accounting/vendor_bills.rst:95
msgid ""
":guilabel:`Product`: Click :guilabel:`Add a line`, then search for and "
"select the product."
msgstr ""
":guilabel:`Produkt`: Kliknij :guilabel:`Dodaj pozycję`, a następnie wyszukaj "
"i wybierz produkt."

#: ../../content/applications/finance/accounting/customer_invoices.rst:53
