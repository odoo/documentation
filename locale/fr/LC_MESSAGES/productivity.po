msgstr ""
":guilabel:`L'appelant quitte la file d'attente (aucun agent n'est connecté)`"

#: ../../content/applications/productivity/phone/axivox/call_queues.rst:131
msgid ":guilabel:`The caller exits the queue (timeout)`"
msgstr ":guilabel:`L'appelant quitte la file d'attente (délai expiré)`"

#: ../../content/applications/productivity/phone/axivox/call_queues.rst:132
msgid ":guilabel:`No one is answering`"
msgstr ":guilabel:`Personne ne répond`"

#: ../../content/applications/productivity/phone/axivox/call_queues.rst:133
