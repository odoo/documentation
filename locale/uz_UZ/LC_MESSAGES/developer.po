msgstr ""
"`href` : (ixtiyoriy) berilgan bo'lsa (va to'g'ri bo'lsa), element matni "
"berilgan href atributiga ega `a` tegiga joylashtiriladi,"

#: ../../content/developer/reference/frontend/registries.rst:286
msgid "`callback` : callback to call when the item is selected,"
msgstr "`callback` : element tanlanganda chaqiriladigan qayta chaqiruv,"

