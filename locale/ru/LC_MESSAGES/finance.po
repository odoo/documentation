#~ msgstr ""
#~ "Валютные курсы обновляются один раз в день с помощью веб-сервиса НБУ."

#~ msgid "International Standards"
#~ msgstr "международные стандарты"

#~ msgid ""
#~ "Odoo accounting supports more than 50 countries. The Odoo core accounting "
