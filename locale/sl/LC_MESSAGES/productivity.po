#: ../../content/applications/productivity/documents.rst:166
msgid ":icon:`fa-pencil-square-o` :guilabel:`Rename`"
msgstr ":icon:`fa-pencil-square-o` :guilabel:`Preimenuj`"

#: ../../content/applications/productivity/documents.rst:167
msgid ""
":icon:`fa-info-circle` :guilabel:`Info & tags`: View the "
"file's :ref:`details <documents/details-panel>` and chatter."
msgstr ""
":icon:`fa-info-circle` :guilabel:`Podatki in oznake`: Oglejte si "
":ref:`podrobnosti <documents/details-panel>` datoteke in klepet."

#: ../../content/applications/productivity/documents.rst:169
