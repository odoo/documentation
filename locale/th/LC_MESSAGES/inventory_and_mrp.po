#: ../../content/applications/inventory_and_mrp/inventory/product_management/product_tracking/create_sn.rst:17
msgid ""
"by clicking the :ref:`Assign Serial Numbers <inventory/product_management/"
"assign-sn>` button on a receipt"
msgstr ""
"โดยคลิกปุ่ม :ref:`กำหนดหมายเลขซีเรียล <inventory/product_management/assign-sn>` บน"
