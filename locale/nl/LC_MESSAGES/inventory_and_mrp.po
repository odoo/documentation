msgstr ""
":ref:`Stel de leveringsmethode in <inventory/shipping_receiving/configure-"
"delivery-method>`."

#: ../../content/applications/inventory_and_mrp/inventory/shipping_receiving/setup_configuration/third_party_shipper.rst:65
msgid ""
":ref:`Activate production environment <inventory/shipping_receiving/"
"production-env>`."
msgstr ""
":ref:`Activeer de productieomgeving <inventory/shipping_receiving/production-"
