msgstr ":guilabel:`Личный телефон`"

#: ../../content/applications/hr/payroll/payroll_localizations/australia.rst:35
msgid ":guilabel:`Date of Birth`"
msgstr ":guilabel:`Дата рождения`"

#: ../../content/applications/hr/payroll/payroll_localizations/australia.rst:None
