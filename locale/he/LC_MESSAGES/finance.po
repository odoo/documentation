msgstr ""
"`מדריכי הממשלה <manuals_>`_ מספקים הוראות ליצירת חשבון ולהפקת אישורי ה-API."

#: ../../content/applications/finance/fiscal_localizations/jordan.rst:106
msgid "Link Odoo to JoFotara"
msgstr "קישור Odoo ל-JoFotara"

