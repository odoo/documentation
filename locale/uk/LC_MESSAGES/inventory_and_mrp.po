msgstr ""

#: ../../content/applications/inventory_and_mrp/manufacturing/advanced_configuration/using_work_centers.rst:None
msgid "The general information tab of the work center form."
msgstr "Вкладка загальної інформації форми виробничого центру."

#: ../../content/applications/inventory_and_mrp/manufacturing/advanced_configuration/using_work_centers.rst:58
