#: ../../content/applications/hr/payroll/payroll_localizations/australia.rst:162
msgid ""
"Add the :guilabel:`Extra Negotiated Super %` on top of the *super guarantee*."
msgstr ""
"*super guarantee*\\ に加えて\\ :guilabel:`Extra Negotiated Super %`\\ を追加"
