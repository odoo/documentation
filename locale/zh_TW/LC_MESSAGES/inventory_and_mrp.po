#: ../../content/applications/inventory_and_mrp/inventory/warehouses_storage/replenishment/reordering_rules.rst:57
msgid ""
"A product must be configured correctly to use reordering rules. Begin by "
"navigating to :menuselection:`Inventory app --> Products --> Products`, then "
"select an existing product, or create a new one by clicking :guilabel:`New`."
msgstr ""
