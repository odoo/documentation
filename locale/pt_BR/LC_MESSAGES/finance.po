msgid "Generate electronic documents from the *Point of Sale* application"
msgstr "Gerar documentos eletrônicos a partir do aplicativo *Ponto de Venda*"

#: ../../content/applications/finance/fiscal_localizations/chile.rst:1054
msgid ""
"Support the required fiscal fields for contacts created in the *Point of "
