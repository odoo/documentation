#: ../../content/applications/general/iot/iot_advanced/troubleshooting.rst:112
msgid "`ERR_IOT_HTTPS_CHECK_CERT_READ_EXCEPTION`"
msgstr "`ERR_IOT_HTTPS_CHECK_CERT_READ_EXCEPTION`"

