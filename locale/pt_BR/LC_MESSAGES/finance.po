msgstr ":guilabel:`Tipo de Transporte`"

#: ../../content/applications/finance/fiscal_localizations/peru.rst:877
msgid ":guilabel:`Reason for Transfer`"
msgstr ":guilabel:`Motivo da Transferência`"

#: ../../content/applications/finance/fiscal_localizations/peru.rst:878
msgid ":guilabel:`Departure start date`"
msgstr ":guilabel:`Data de início da partida`"

#: ../../content/applications/finance/fiscal_localizations/peru.rst:880
