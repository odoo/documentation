#: ../../content/applications/services/field_service.rst:8
msgid "Field Service"
msgstr "Felt tjeneste"

#: ../../content/applications/services/field_service.rst:11
msgid ""
"`Odoo Tutorials: Field Service <https://www.odoo.com/slides/field-"
"service-49>`_"
