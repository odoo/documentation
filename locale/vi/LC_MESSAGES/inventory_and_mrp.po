msgstr "Quy tắc tái đặt hàng: Tối thiểu: 5, Tối đa: 10"

#: ../../content/applications/inventory_and_mrp/inventory/warehouses_storage/replenishment/report.rst:95
msgid "Vendor lead time: 1 day"
msgstr "Thời gian hoàn thành của nhà cung cấp: 1 ngày"

#: ../../content/applications/inventory_and_mrp/inventory/warehouses_storage/replenishment/report.rst:97
msgid ""
"8 units are needed for an |SO| on Feb 23. That means, on Feb 23, there will "
