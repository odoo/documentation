#: ../../content/applications/sales/point_of_sale/payment_methods/terminals/ingenico.rst:9
msgid ""
"Ingenico payment terminals require an :doc:`IoT system </applications/"
"general/iot>`."
msgstr ""
"Ingenico 決済端末には\\ :doc:`IoT システム </applications/general/iot>`\\ が"
"必要です。"

