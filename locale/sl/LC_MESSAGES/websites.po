msgstr ""

#: ../../content/applications/websites/website/website_creation.rst:88
msgid ""
"When running an online shop, ensure the :guilabel:`Import Products` option "
"is enabled to extract product data."
msgstr ""

#: ../../content/applications/websites/website/website_creation.rst:90
msgid "To submit the request, click :guilabel:`Import my website`."
msgstr ""

#: ../../content/applications/websites/website/website_creation.rst:92
