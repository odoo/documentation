msgid "**Remuneration components:**"
msgstr "**Компоненты вознаграждения:**"

#: ../../content/applications/hr/payroll/payroll_localizations/belgium.rst:1852
msgid "Per pay period (daily, weekly, bi-weekly, or monthly):"
msgstr ""
