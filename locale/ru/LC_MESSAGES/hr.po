msgstr "Настройте записи новых сотрудников."

#: ../../content/applications/hr/employees.rst:20
#: ../../content/applications/hr/employees/departments.rst:3
msgid "Departments"
msgstr "Отделы"

#: ../../content/applications/hr/employees.rst:20
