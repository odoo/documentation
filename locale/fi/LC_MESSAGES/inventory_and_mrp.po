#: ../../content/applications/inventory_and_mrp/inventory/shipping_receiving/setup_configuration/print_on_validation.rst:None
msgid "Show the *Print on Validation* option in the \"Pick\" *Operation Type*."
msgstr ""
"Näytä *Tulosta vahvistuksessa* -asetus \"Keräily\"-*toimintotyypin* "
