msgid "``user_company_vat`` (optional)"
msgstr "``user_company_vat`` (ixtiyoriy)"

#: ../../content/developer/reference/extract_api.rst:116
msgid "VAT number of the user."
msgstr "Foydalanuvchining QQS raqami."

#: ../../content/developer/reference/extract_api.rst:117
msgid "``user_company_name`` (optional)"
msgstr "``user_company_name`` (ixtiyoriy)"

#: ../../content/developer/reference/extract_api.rst:118
msgid "Name of the user’s company."
msgstr "Foydalanuvchi kompaniyasining nomi."

#: ../../content/developer/reference/extract_api.rst:120
msgid "``user_company_country_code`` (optional)"
msgstr "``user_company_country_code`` (ixtiyoriy)"

#: ../../content/developer/reference/extract_api.rst:120
msgid ""
"Country code of the user. Format: `ISO3166 alpha-2 <https://www.iban.com"
"/country-codes>`_."
msgstr ""
"Foydalanuvchining mamlakat kodi. Format: `ISO3166 alpha-2 "
"<https://www.iban.com/country-codes>`_."

#: ../../content/developer/reference/extract_api.rst:122
msgid "``user_lang`` (optional)"
msgstr "``user_lang`` (ixtiyoriy)"

#: ../../content/developer/reference/extract_api.rst:123
msgid ""
"The user language. Format: *language_code + _ + locale* (e.g. fr_FR, "
"en_US)."
msgstr ""
"Foydalanuvchi tili. Format: *language_code + _ + locale* (masalan fr_FR, en_US)."

#: ../../content/developer/reference/extract_api.rst:124
msgid "``user_email`` (optional)"
msgstr "``user_email`` (ixtiyoriy)"

#: ../../content/developer/reference/extract_api.rst:125
msgid "The user email."
msgstr "Foydalanuvchi elektron pochtasi."

#: ../../content/developer/reference/extract_api.rst:126
msgid "``purchase_order_regex`` (optional)"
msgstr "``purchase_order_regex`` (ixtiyoriy)"

#: ../../content/developer/reference/extract_api.rst:127
msgid ""
