"correct business."
msgstr ""
"Lasku reititetään sitten San Marinon erityistoimiston kautta oikealle "
"yritykselle."

#: ../../content/applications/finance/fiscal_localizations/italy.rst:518
msgid "Vendor Bills"
msgstr "Ostolaskut"

#: ../../content/applications/finance/fiscal_localizations/italy.rst:520
