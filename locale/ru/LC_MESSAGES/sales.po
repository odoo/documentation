#: ../../content/applications/sales/sales/ebay_connector/setup.rst:101
msgid ""
":guilabel:`End item's listing` button: end a listing on eBay directly from "
"Odoo."
msgstr ""

#: ../../content/applications/sales/sales/ebay_connector/setup.rst:102
