msgstr "Design din hjemmeside ved hjælp af byggeblokke og hjemmesidetemaer."

#: ../../content/applications/websites/website.rst:22
#: ../../content/applications/websites/website/structure.rst:7
msgid "Structure"
msgstr "Struktur"

#: ../../content/applications/websites/website.rst:22
