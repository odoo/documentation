msgid ":guilabel:`Company ID` : Enter the business's state ID number."
msgstr ":guilabel:`कंपनी आईडी`: बिज़नेस का राज्य आईडी नंबर दर्ज करें।"

#: ../../content/applications/hr/payroll/payroll_localizations/united_states.rst:88
msgid ""
