msgstr ":guilabel:`Kiinteä hinta`: `200`"

#: ../../content/applications/inventory_and_mrp/inventory/shipping_receiving/setup_configuration/new_delivery_method.rst:66
msgid ":guilabel:`Delivery Product`: :guilabel:`Furniture Delivery (manual)`"
msgstr ":guilabel:`Toimitustuote`: :guilabel:`Furniture Delivery (manual)`"

#: ../../content/applications/inventory_and_mrp/inventory/shipping_receiving/setup_configuration/new_delivery_method.rst:0
