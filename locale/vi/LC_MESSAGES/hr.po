msgstr "Lập kế hoạch trước cho kỳ nghỉ tập thể và ngày lễ thay thế"

#: ../../content/applications/hr/payroll/payroll_localizations/belgium.rst:1893
msgid ""
"Pay workers their holiday pay (including early holiday pay if applicable)"
msgstr ""
"Trả cho người lao động tiền nghỉ phép (bao gồm tiền nghỉ phép trả trước nếu "
