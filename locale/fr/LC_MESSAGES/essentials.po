#: ../../content/applications/essentials/html_editor.rst:283
msgid ""
"Choose from the `Flexible`, `16:9`, `4:3`, `1:1`, or `2:3` aspect ratios."
msgstr ""
"Choisir parmi les rapports d'aspect `Flexible`, `16:9`, `4:3`, `1:1` ou "
