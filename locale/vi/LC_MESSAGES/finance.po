msgstr "Phần \"Chi tiết tài khoản\" trên bảng điều khiển Employment Hero"

#: ../../content/applications/finance/fiscal_localizations/australia.rst:899
msgid ""
"The **Payroll URL** is pre-filled with `https://keypay.yourpayroll.com.au`."
msgstr ""

#: ../../content/applications/finance/fiscal_localizations/australia.rst:902
msgid "Do not change the **pre-filled Payroll URL**"
msgstr ""

#: ../../content/applications/finance/fiscal_localizations/australia.rst:904
msgid ""
"You can find the **Business ID** in the Employment Hero URL. (i.e., `189241`)"
