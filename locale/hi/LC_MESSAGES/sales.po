msgstr ""
"वैकल्पिक रूप से, पसंदीदा :guilabel:`कैटगरी` को चुनने के लिए :guilabel:`पॉइंट ऑफ़ सेल` टैब "
"पर क्लिक करें।"

#: ../../content/applications/sales/point_of_sale/products.rst:108
msgid ":doc:`/applications/sales/sales/products_prices/products/variants`"
msgstr ":doc:`/applications/sales/sales/products_prices/products/variants`"

#: ../../content/applications/sales/point_of_sale/products.rst:113
