#: ../../content/applications/inventory_and_mrp/inventory/product_management/configure/package.rst:199
msgid "View packages"
msgstr "Visualizzare i colli"

#: ../../content/applications/inventory_and_mrp/inventory/product_management/configure/package.rst:201
msgid ""
"To view all packages, go to :menuselection:`Inventory app --> Products --> "
"Packages`. By default, packages are shown in Kanban view."
