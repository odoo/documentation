msgstr "Tipi sprožilcev za podrejene aktivnosti strežniškega dejanja."

#: ../../content/applications/marketing/marketing_automation/workflow_activities.rst:311
msgid ""
"Triggers the child activity on the following condition of the parent "
"activity:"
msgstr "Sproži podrejeno aktivnost ob naslednjem pogoju nadrejene aktivnosti:"

