msgstr "Nhấp vào :guilabel:`Lưu thay đổi` ở cuối trang."

#: ../../content/applications/finance/payment_providers/adyen.rst:37
msgid ""
"Go to :menuselection:`Developers --> Webhooks` in the left menu and "
"click :guilabel:`Create new webhook`."
msgstr ""

#: ../../content/applications/finance/payment_providers/adyen.rst:39
