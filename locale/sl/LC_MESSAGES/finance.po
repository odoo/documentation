msgstr ""
":guilabel:`Uporabniško ime`: vnesite uporabniško ime za prijavo v strežnik."

#: ../../content/applications/finance/fiscal_localizations/chile.rst:184
msgid ":guilabel:`Password`: enter the server login password."
msgstr ":guilabel:`Geslo`: vnesite geslo za prijavo v strežnik."

