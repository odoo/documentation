msgstr ""
"เมื่อเลือกนโยบายแล้ว ให้คลิก :guilabel:`บันทึก` เพื่อบันทึกการเปลี่ยนแปลง"

#: ../../content/applications/inventory_and_mrp/purchase/manage_deals/manage.rst:42
