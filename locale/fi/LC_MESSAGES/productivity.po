":ref:`kansikuva <knowledge/articles_editing/cover>` :ref:`otsikkohymiöllä "
"<knowledge/articles_editing/emoji>`."

#: ../../content/applications/productivity/knowledge.rst:69
msgid "Text editor toolbar"
msgstr "Tekstieditorin työkalurivi"

