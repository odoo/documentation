#: ../../content/applications/finance/fiscal_localizations/malaysia.rst:126
msgid ":guilabel:`Document - Cancel`"
msgstr ":guilabel:`Documento - Cancelar`"

#: ../../content/applications/finance/fiscal_localizations/malaysia.rst:127
