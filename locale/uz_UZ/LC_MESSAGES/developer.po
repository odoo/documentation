msgstr ""
"pastturning nomi, bildirishnomani moslashtirish qalqib chiqadigan oynasida ko'rsatiladi"

#: ../../content/developer/reference/backend/mixins.rst:240
msgid "``description`` - :class:`~odoo.fields.Char`"
msgstr "``description`` - :class:`~odoo.fields.Char`"

#: ../../content/developer/reference/backend/mixins.rst:240
