msgstr "$954.55"

#: ../../content/applications/hr/payroll/payroll_localizations/australia.rst:500
msgid "Laundry allowance"
msgstr "Zasiłek na pranie"

#: ../../content/applications/hr/payroll/payroll_localizations/australia.rst:501
